<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Studio Light theme -->
    <SolidColorBrush x:Key="BgCanvas"      Color="#DFE3E8" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgDark"        Color="#F6F7F9" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgPanel"       Color="#FDFDFE" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgSidebar"     Color="#ECEEF1" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgModal"       Color="#FFFFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgHover"       Color="#E4E8EC" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgControl"     Color="#EEF0F3" po:Freeze="True"/>
    <SolidColorBrush x:Key="BorderDim"     Color="#E0E3E8" po:Freeze="True"/>
    <SolidColorBrush x:Key="Accent"        Color="#F2A93B" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentText"    Color="#9A6B14" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentDim"     Color="#FBEAD0" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentBorder"  Color="#E0B36A" po:Freeze="True"/>
    <SolidColorBrush x:Key="SelectionAccent" Color="#F2A93B" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentLogo"    Color="#C07F12" po:Freeze="True"/>
    <SolidColorBrush x:Key="TextPrimary"   Color="#1A1D22" po:Freeze="True"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#525A64" po:Freeze="True"/>
    <SolidColorBrush x:Key="TextDim"       Color="#9AA1AB" po:Freeze="True"/>
    <SolidColorBrush x:Key="TextFooter"    Color="#9AA1AB" po:Freeze="True"/>
    <SolidColorBrush x:Key="DangerRed"     Color="#DC2626" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgDragHandle"  Color="#C4CAD2" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgScrollThumb" Color="#66C07F12" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgOverlay"     Color="#66000000" po:Freeze="True"/>

    <!-- Ribbon / Clinical redesign tokens — steel chrome over a light operating field -->
    <SolidColorBrush x:Key="ChromeBg"        Color="#2C3A4C" po:Freeze="True"/>
    <SolidColorBrush x:Key="ChromeText"      Color="#FFFFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="ChromeTextDim"   Color="#AEB9C7" po:Freeze="True"/>
    <SolidColorBrush x:Key="ChromeHover"     Color="#3C4C60" po:Freeze="True"/>
    <SolidColorBrush x:Key="RibbonBg"        Color="#FFFFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="RibbonBand"      Color="#F2F5F8" po:Freeze="True"/>
    <SolidColorBrush x:Key="RibbonGroupLabel" Color="#8A93A0" po:Freeze="True"/>
    <SolidColorBrush x:Key="RibbonBtnHover"  Color="#E9EDF1" po:Freeze="True"/>
    <SolidColorBrush x:Key="ZoomTrack"       Color="#46566B" po:Freeze="True"/>

    <sys:Double x:Key="GrainOpacity">0.05</sys:Double>

    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                      Color="#FBEAD0" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                  Color="#9A6B14" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"     Color="#FBEAD0" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#9A6B14" po:Freeze="True"/>

</ResourceDictionary>
