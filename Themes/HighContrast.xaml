<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Studio High Contrast theme -->
    <SolidColorBrush x:Key="BgCanvas"      Color="#000000" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgDark"        Color="#000000" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgPanel"       Color="#0A0A0A" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgSidebar"     Color="#000000" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgModal"       Color="#000000" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgHover"       Color="#1F1F1F" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgControl"     Color="#141414" po:Freeze="True"/>
    <SolidColorBrush x:Key="BorderDim"     Color="#FFFFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="Accent"        Color="#FFB000" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentText"    Color="#FFB000" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentDim"     Color="#2A1D00" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentBorder"  Color="#FFB000" po:Freeze="True"/>
    <SolidColorBrush x:Key="SelectionAccent" Color="#FFB000" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentLogo"    Color="#FFB000" po:Freeze="True"/>
    <SolidColorBrush x:Key="TextPrimary"   Color="#FFFFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#E0E0E0" po:Freeze="True"/>
    <SolidColorBrush x:Key="TextDim"       Color="#BFBFBF" po:Freeze="True"/>
    <SolidColorBrush x:Key="TextFooter"    Color="#BFBFBF" po:Freeze="True"/>
    <SolidColorBrush x:Key="DangerRed"     Color="#FF5555" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgDragHandle"  Color="#FFFFFF" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgScrollThumb" Color="#99FFB000" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgOverlay"     Color="#DD000000" po:Freeze="True"/>
    <sys:Double x:Key="GrainOpacity">0</sys:Double>

    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                      Color="#2A1D00" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                  Color="#FFB000" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"     Color="#2A1D00" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FFB000" po:Freeze="True"/>

</ResourceDictionary>
