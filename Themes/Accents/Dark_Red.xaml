<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">
    <!-- Dark base, Red accent — tuned to surgical red (Clinical) -->
    <SolidColorBrush x:Key="Accent"        Color="#F04458" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentText"    Color="#FF8A98" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentDim"     Color="#3A1219" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentBorder"  Color="#8C1C2C" po:Freeze="True"/>
    <SolidColorBrush x:Key="SelectionAccent" Color="#F04458" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentLogo"    Color="#F04458" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgScrollThumb" Color="#5BF04458" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                      Color="#3A1219" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                  Color="#FF8A98" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"     Color="#3A1219" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FF8A98" po:Freeze="True"/>
</ResourceDictionary>
