<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">
    <!-- Light base, Red accent — tuned to surgical red (Clinical) -->
    <SolidColorBrush x:Key="Accent"        Color="#E11D38" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentText"    Color="#B11228" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentDim"     Color="#FDEAEC" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentBorder"  Color="#E11D38" po:Freeze="True"/>
    <SolidColorBrush x:Key="SelectionAccent" Color="#E11D38" po:Freeze="True"/>
    <SolidColorBrush x:Key="AccentLogo"    Color="#C8122B" po:Freeze="True"/>
    <SolidColorBrush x:Key="BgScrollThumb" Color="#66C8122B" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                      Color="#FDEAEC" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                  Color="#B11228" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"     Color="#FDEAEC" po:Freeze="True"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#B11228" po:Freeze="True"/>
</ResourceDictionary>
